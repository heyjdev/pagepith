    "check": "npm test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mozilla/readability": "0.6.0",
    "turndown": "7.2.0",
    "turndown-plugin-gfm": "1.0.2"
  },
  "devDependencies": {
    "esbuild": "0.25.6",
    "jsdom": "29.1.1"
  },
  "license": "MIT"
}
